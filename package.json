{
  "name": "ira_ugc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "setup": "node scripts/install-with-env.js",
    "install:safe": "pnpm exec dotenv -e .env -- pnpm install --legacy-peer-deps",
    "install:safe:prisma:inrealart": "pnpm exec dotenv -e .env -- pnpm install @InRealArt/prisma-schema",
    "prisma:copy-schema": "mkdir -p prisma && cp node_modules/@InRealArt/prisma-schema/schema.prisma prisma/schema.prisma",
    "update:schema:inrealart": "node scripts/update-prisma-schema.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@InRealArt/prisma-schema": "^1.2.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
